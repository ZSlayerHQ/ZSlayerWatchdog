<Application x:Class="ZSlayerCommandCenter.Launcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!-- ── Colors ──────────────────────────────────────── -->
        <Color x:Key="BgDark">#1a1710</Color>
        <Color x:Key="BgPanel">#1e1b14</Color>
        <Color x:Key="CardBg">#232019</Color>
        <Color x:Key="Gold">#c8aa6e</Color>
        <Color x:Key="TextPrimary">#e8dcc8</Color>
        <Color x:Key="TextDimmed">#7a7060</Color>
        <Color x:Key="TextMuted">#5a5448</Color>
        <Color x:Key="GreenStatus">#4a7c59</Color>
        <Color x:Key="RedStatus">#8b3a3a</Color>
        <Color x:Key="OrangeStatus">#c87a3e</Color>
        <Color x:Key="ButtonBg">#2a2520</Color>
        <Color x:Key="ButtonHover">#3a3530</Color>
        <Color x:Key="BorderSubtle">#3a3530</Color>

        <!-- ── Brushes ─────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}"/>
        <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource Gold}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextDimmedBrush" Color="{StaticResource TextDimmed}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="GreenStatusBrush" Color="{StaticResource GreenStatus}"/>
        <SolidColorBrush x:Key="RedStatusBrush" Color="{StaticResource RedStatus}"/>
        <SolidColorBrush x:Key="OrangeStatusBrush" Color="{StaticResource OrangeStatus}"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="{StaticResource ButtonBg}"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ButtonHover}"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>

        <!-- ── GoldButton Style ────────────────────────────── -->
        <Style x:Key="GoldButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── RedButton Style ─────────────────────────────── -->
        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource GoldButton}">
            <Setter Property="Foreground" Value="{StaticResource RedStatusBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RedStatusBrush}"/>
        </Style>

        <!-- ── TitleBarButton Style ────────────────────────── -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimmedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── GoldSlider Style ────────────────────────────── -->
        <Style x:Key="GoldSlider" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2"
                                    Background="{StaticResource ButtonBgBrush}"
                                    VerticalAlignment="Center" Margin="7,0"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton OverridesDefaultStyle="True"
                                                  IsTabStop="False" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{StaticResource GoldBrush}"
                                                        VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton OverridesDefaultStyle="True"
                                                  IsTabStop="False" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="#2a2520"
                                                        VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{StaticResource GoldBrush}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle Switch Style ────────────────────────── -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="38" Height="20"
                                CornerRadius="10"
                                Background="{StaticResource BorderSubtleBrush}">
                            <Ellipse x:Name="Thumb" Width="14" Height="14"
                                     Fill="{StaticResource TextDimmedBrush}"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{StaticResource GoldBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#1a1710"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment"
                                        Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin"
                                        Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stat Label Style ────────────────────────────── -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimmedBrush}"/>
        </Style>

        <!-- ── Stat Value Style ────────────────────────────── -->
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

    </Application.Resources>
</Application>
