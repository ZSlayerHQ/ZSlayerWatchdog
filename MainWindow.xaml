<Window x:Class="ZSlayerCommandCenter.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="False"
        Background="{StaticResource BgDarkBrush}"
        Width="560" Height="440" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="ZSLAYER — WATCHDOG"
        Icon="app.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- ══ Title Bar ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource GoldBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="ZSLAYER — WATCHDOG"
                           Foreground="{StaticResource GoldBrush}"
                           FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                <TextBlock x:Name="UpdateLink" Visibility="Collapsed"
                           Foreground="{StaticResource GoldBrush}"
                           FontSize="11" Cursor="Hand"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,75,0"
                           MouseLeftButtonDown="UpdateLink_Click"/>

                <TextBlock x:Name="VersionLabel" Text="v2.4.0"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="10"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,75,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Content="—" Style="{StaticResource TitleBarButton}"
                            Click="Minimize_Click"/>
                    <Button Content="✕" Style="{StaticResource TitleBarButton}"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Cards Area ═════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Server Card ────────────────────────────── -->
            <Border Grid.Column="0" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="SPT SERVER" Foreground="{StaticResource GoldBrush}"
                                       FontSize="12" FontWeight="Bold" Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border x:Name="SvrStatusPill" HorizontalAlignment="Right"
                                CornerRadius="10" Padding="8,3"
                                Background="{StaticResource RedStatusBrush}">
                            <TextBlock x:Name="SvrStatusText" Text="● Stopped"
                                       Foreground="White" FontSize="10"/>
                        </Border>
                    </Grid>

                    <!-- Stat Labels -->
                    <Grid Grid.Row="1" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="UPTIME" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Column="1" Text="PID" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Column="2" Text="AUTO-RST" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Column="3" Text="AUTO-START" Style="{StaticResource StatLabel}"/>
                    </Grid>

                    <!-- Stat Values -->
                    <Grid Grid.Row="2" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SvrUptimeVal" Grid.Column="0" Text="--"
                                   Style="{StaticResource StatValue}"/>
                        <TextBlock x:Name="SvrPidVal" Grid.Column="1" Text="--"
                                   Style="{StaticResource StatValue}"/>
                        <CheckBox x:Name="SvrAutoRstVal" Grid.Column="2"
                                 Style="{StaticResource ToggleSwitch}"
                                 Checked="SvrAutoRst_Toggle" Unchecked="SvrAutoRst_Toggle"/>
                        <CheckBox x:Name="SvrAutoStartVal" Grid.Column="3"
                                  Style="{StaticResource ToggleSwitch}"
                                  Checked="SvrAutoStart_Toggle" Unchecked="SvrAutoStart_Toggle"/>
                    </Grid>

                    <!-- Session Timeout Label -->
                    <Grid Grid.Row="3" Margin="0,0,0,4">
                        <TextBlock Text="SESSION TIMEOUT" Style="{StaticResource StatLabel}"/>
                        <TextBlock x:Name="SvrTimeoutLabel" HorizontalAlignment="Right"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11" FontWeight="Bold"/>
                    </Grid>

                    <!-- Session Timeout Slider -->
                    <Slider x:Name="SvrTimeoutSlider" Grid.Row="4"
                            Style="{StaticResource GoldSlider}"
                            Minimum="1" Maximum="30"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            Margin="0,0,0,14"/>

                    <!-- Crashes Label -->
                    <TextBlock Grid.Row="5" Text="CRASHES TODAY"
                               Style="{StaticResource StatLabel}" Margin="0,0,0,2"/>

                    <!-- Crashes Value -->
                    <TextBlock x:Name="SvrCrashVal" Grid.Row="6" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="8" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="BtnSvrStart" Content="Start"
                                Style="{StaticResource GoldButton}" Margin="0,0,6,0"
                                Click="SvrStart_Click"/>
                        <Button x:Name="BtnSvrStop" Content="Stop"
                                Style="{StaticResource GoldButton}" Margin="0,0,6,0"
                                Click="SvrStop_Click"/>
                        <Button x:Name="BtnSvrRestart" Content="Restart"
                                Style="{StaticResource GoldButton}"
                                Click="SvrRestart_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Headless Card ──────────────────────────── -->
            <Border Grid.Column="2" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="HEADLESS" Foreground="{StaticResource GoldBrush}"
                                       FontSize="12" FontWeight="Bold" Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border x:Name="HdlStatusPill" HorizontalAlignment="Right"
                                CornerRadius="10" Padding="8,3"
                                Background="{StaticResource RedStatusBrush}">
                            <TextBlock x:Name="HdlStatusText" Text="● Stopped"
                                       Foreground="White" FontSize="10"/>
                        </Border>
                    </Grid>

                    <!-- Stat Labels Row 1 -->
                    <Grid Grid.Row="1" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="UPTIME" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Column="1" Text="PID" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Column="2" Text="AUTO-RST" Style="{StaticResource StatLabel}"/>
                    </Grid>

                    <!-- Stat Values Row 1 -->
                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="HdlUptimeVal" Grid.Column="0" Text="--"
                                   Style="{StaticResource StatValue}"/>
                        <TextBlock x:Name="HdlPidVal" Grid.Column="1" Text="--"
                                   Style="{StaticResource StatValue}"/>
                        <CheckBox x:Name="HdlAutoRstVal" Grid.Column="2"
                                 Style="{StaticResource ToggleSwitch}"
                                 Checked="HdlAutoRst_Toggle" Unchecked="HdlAutoRst_Toggle"/>
                    </Grid>

                    <!-- Stat Labels Row 2 -->
                    <Grid Grid.Row="3" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="AUTO-START" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Column="1" Text="START DELAY" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Column="2" Text="PROFILE" Style="{StaticResource StatLabel}"/>
                    </Grid>

                    <!-- Stat Values Row 2 -->
                    <Grid Grid.Row="4" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="HdlAutoStartVal" Grid.Column="0"
                                 Style="{StaticResource ToggleSwitch}"
                                 Checked="HdlAutoStart_Toggle" Unchecked="HdlAutoStart_Toggle"/>
                        <TextBlock x:Name="HdlDelayVal" Grid.Column="1"
                                   Style="{StaticResource StatValue}"/>
                        <TextBlock x:Name="HdlProfileVal" Grid.Column="2"
                                   Style="{StaticResource StatValue}" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <!-- Restart After Raids Label -->
                    <Grid Grid.Row="5" Margin="0,0,0,4">
                        <TextBlock Text="RESTART AFTER RAIDS" Style="{StaticResource StatLabel}"/>
                        <TextBlock x:Name="HdlRaidLabel" HorizontalAlignment="Right"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11" FontWeight="Bold"/>
                    </Grid>

                    <!-- Restart After Raids Slider -->
                    <Slider x:Name="HdlRaidSlider" Grid.Row="6"
                            Style="{StaticResource GoldSlider}"
                            Minimum="0" Maximum="10"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            Margin="0,0,0,14"/>

                    <!-- Crashes Label -->
                    <TextBlock Grid.Row="7" Text="CRASHES TODAY"
                               Style="{StaticResource StatLabel}" Margin="0,0,0,2"/>

                    <!-- Crashes Value -->
                    <TextBlock x:Name="HdlCrashVal" Grid.Row="8" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="10" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="BtnHdlStart" Content="Start"
                                Style="{StaticResource GoldButton}" Margin="0,0,6,0"
                                Click="HdlStart_Click"/>
                        <Button x:Name="BtnHdlStop" Content="Stop"
                                Style="{StaticResource GoldButton}" Margin="0,0,6,0"
                                Click="HdlStop_Click"/>
                        <Button x:Name="BtnHdlRestart" Content="Restart"
                                Style="{StaticResource GoldButton}"
                                Click="HdlRestart_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ Bottom Bar ═════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <TextBlock x:Name="ApiLabel"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="│" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Text="MIN→TRAY" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="9" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <CheckBox x:Name="TrayToggleVal"
                             Style="{StaticResource ToggleSwitch}"
                             Checked="TrayToggle_Click" Unchecked="TrayToggle_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnCC" Content="Open Command Center"
                            Style="{StaticResource GoldButton}" Margin="0,0,8,0"
                            Click="OpenCC_Click"/>
                    <Button x:Name="BtnQuit" Content="Quit"
                            Style="{StaticResource RedButton}"
                            Click="Quit_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
